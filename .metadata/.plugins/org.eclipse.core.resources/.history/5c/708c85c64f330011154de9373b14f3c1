#include "main.h"
#include "pzem004t.h"
#include <stdio.h>
#include "lcd_i2c.h"

extern UART_HandleTypeDef huart1;   // PZEM용
extern UART_HandleTypeDef huart3;   // 시리얼 모니터용
extern I2C_HandleTypeDef hi2c1;

PZEM_Data_t pzem_data;
PZEM_Status_t pzem_status;
uint32_t pzem_tick = 0;
/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */
	HAL_Init();
	    SystemClock_Config();

	    MX_GPIO_Init();
	    MX_USART1_UART_Init();   // PZEM
	    MX_USART3_UART_Init();   // Serial monitor
	    MX_I2C1_Init();          // LCD

	    LCD_Init();
	    LCD_Clear();

	    printf("PZEM + LCD start\r\n");
	    LCD_PrintAt(0, 0, "PZEM LCD Start");

	    HAL_Delay(1000);
	    LCD_Clear();
  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART1_UART_Init();
  MX_USART2_UART_Init();
  MX_USART3_UART_Init();
  MX_I2C1_Init();
  /* USER CODE BEGIN 2 */
  for (uint8_t addr = 1; addr < 128; addr++)
  {
      if (HAL_I2C_IsDeviceReady(&hi2c1, addr << 1, 1, 10) == HAL_OK)
      {
          printf("I2C found: 0x%02X\r\n", addr);
      }
  }
  HAL_Delay(1000);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */
	  if (HAL_GetTick() - pzem_tick >= 1000)
	          {
	              pzem_tick = HAL_GetTick();

	              pzem_status = PZEM_ReadMeasurements(&huart1, PZEM_DEFAULT_ADDR, &pzem_data);

	              if (pzem_status == PZEM_OK)
	              {
	                  char line1[17];
	                  char line2[17];

	                  printf("V=%.1f V, I=%.3f A, P=%.1f W, E=%.3f kWh, F=%.1f Hz, PF=%.2f\r\n",
	                         pzem_data.voltage,
	                         pzem_data.current,
	                         pzem_data.power,
	                         pzem_data.energy,
	                         pzem_data.frequency,
	                         pzem_data.pf);

	                  snprintf(line1, sizeof(line1), "V:%5.1f I:%4.2f",
	                           pzem_data.voltage, pzem_data.current);
	                  snprintf(line2, sizeof(line2), "P:%5.1f PF:%4.2f",
	                           pzem_data.power, pzem_data.pf);

	                  LCD_Clear();
	                  LCD_PrintAt(0, 0, line1);
	                  LCD_PrintAt(1, 0, line2);
	              }
	              else
	              {
	                  printf("PZEM read error: %d\r\n", pzem_status);
	                  LCD_Clear();
	                  LCD_PrintAt(0, 0, "PZEM Error");
	              }
	          }
    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

